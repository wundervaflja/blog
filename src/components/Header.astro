---
const pathname = Astro.url.pathname;
const isUa = pathname.startsWith("/ua");
const enPath = isUa ? pathname.replace(/^\/ua/, "") || "/" : pathname;
const uaPath = isUa ? pathname : `/ua${pathname === "/" ? "" : pathname}`;
---

<header class="site-header">
    <div class="container">
        <a href={isUa ? "/ua/" : "/"} class="site-logo"
            ><span class="tilde">~</span>/devnullgor</a
        >
        <nav>
            <a
                href={isUa ? "/ua/blog/" : "/blog/"}
                class:list={[{ active: pathname.includes("/blog") }]}
            >
                {isUa ? "/блог" : "/blog"}
            </a>
            <a
                href="/projects/"
                class:list={[{ active: pathname.startsWith("/projects") }]}
            >
                {isUa ? "/проєкти" : "/projects"}
            </a>
            <a
                href={isUa ? "/ua/about/" : "/about/"}
                class:list={[{ active: pathname.includes("/about") }]}
            >
                {isUa ? "/про мене" : "/about"}
            </a>
            <span class="lang-switch"
                >/language{"{"}<a href={enPath} class:list={[{ active: !isUa }]}
                    >en</a
                >,<a href={uaPath} class:list={[{ active: isUa }]}>ua</a>{
                    "}"
                }</span
            >
            <button
                class="theme-toggle"
                id="theme-toggle"
                aria-label="Toggle theme">◐</button
            >
        </nav>
    </div>
</header>

<script>
    const btn = document.getElementById("theme-toggle");
    btn?.addEventListener("click", () => {
        const html = document.documentElement;
        const isLight = html.classList.contains("light");
        html.classList.toggle("light", !isLight);
        html.classList.toggle("dark", isLight);
        localStorage.setItem("theme", isLight ? "dark" : "light");
    });
</script>
