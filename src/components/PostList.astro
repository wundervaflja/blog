---
interface Post {
  id: string;
  data: {
    title: string;
    date: Date;
    tags?: string[];
  };
}

interface Props {
  posts: Post[];
  basePath?: string;
}

const { posts, basePath = '/blog' } = Astro.props;

function formatDate(date: Date): string {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  });
}

function getPostUrl(id: string, date: Date): string {
  const year = date.getFullYear();
  return `${basePath}/${year}/${id}/`;
}
---
<ul class="post-list">
  {posts.map((post) => (
    <li>
      <a href={getPostUrl(post.id, post.data.date)} class="post-title">
        {post.data.title}
      </a>
      <time class="post-date" datetime={post.data.date.toISOString()}>
        {formatDate(post.data.date)}
      </time>
    </li>
  ))}
</ul>
