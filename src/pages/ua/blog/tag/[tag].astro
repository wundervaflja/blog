---
import Base from '../../../../layouts/Base.astro';
import PostList from '../../../../components/PostList.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blogUa', ({ data }) => !data.draft);
  const allTags = [...new Set(posts.flatMap(p => p.data.tags || []))];

  return allTags.map(tag => ({
    params: { tag },
    props: {
      posts: posts
        .filter(p => p.data.tags?.includes(tag))
        .sort((a, b) => b.data.date.getTime() - a.data.date.getTime()),
    },
  }));
}

const { tag } = Astro.params;
const { posts } = Astro.props;
---
<Base title={`#${tag}`} description={`Пости з тегом ${tag}`}>
  <h1>#{tag}<span class="cursor"></span></h1>
  <p style="margin-bottom: 2rem;">
    <a href="/ua/blog/">← всі пости</a>
  </p>
  <PostList posts={posts} basePath="/ua/blog" />
</Base>
